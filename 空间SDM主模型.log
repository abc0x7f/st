. * ------------------------------
. * 1. Mata 辅助函数
. * ------------------------------
. mata:
------------------------------------------------- mata (type end to exit) -----
: real matrix row_normalize(real matrix W)
> {
>     real scalar i, s
>     real matrix R
> 
>     R = W
>     for (i = 1; i <= rows(R); i++) {
>         s = sum(R[i,])
>         if (s != 0) {
>             R[i,] = R[i,] :/ s
>         }
>     }
>     return(R)
> }

: end
-------------------------------------------------------------------------------

. 
. * ------------------------------
. * 2. 读取空间矩阵
. * ------------------------------
. capture program drop build_w_matrix

. program define build_w_matrix, rclass
  1.     syntax , WFILE(string) WNAME(name)
  2. 
.     preserve
  3.         import delimited using "`wfile'", clear varnames(1) encoding(utf8)
>  stringcols(1)
  4.         drop province
  5.         unab wvars : _all
  6.         mkmat `wvars', matrix(`wname'_raw)
  7.     restore
  8. 
.     mata: st_matrix("`wname'", row_normalize(st_matrix("`wname'_raw")))
  9.     matrix drop `wname'_raw
 10.     return local wname "`wname'"
 11. end

. 
. * ------------------------------
. * 3. 主面板数据
. * ------------------------------
. tempfile panel_raw

. import delimited using "${DATA_FILE}", clear varnames(1) encoding(utf8)
(9 vars, 240 obs)

. keep province year eff lntl ind urb rd open es

. drop if missing(province, year, eff, lntl, ind, urb, rd, open, es)
(0 observations deleted)

. replace province = trim(province)
(0 real changes made)

. destring year eff lntl ind urb rd open es, replace force
year already numeric; no replace
eff already numeric; no replace
lntl already numeric; no replace
ind already numeric; no replace
urb already numeric; no replace
rd already numeric; no replace
open already numeric; no replace
es already numeric; no replace

. sort province year

. save "`panel_raw'", replace
