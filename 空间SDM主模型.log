. * ------------------------------
. * 5. 单个矩阵的模型估计
. * ------------------------------
. capture program drop run_sdm_model

. program define run_sdm_model
  1.     syntax , TAG(string) LABEL(string) WFILE(string)
  2. 
.     tempname W RTAB
  3.     local k = 0
  4. 
.     quietly build_w_matrix, wfile("`wfile'") wname(`W')
  5.     local WNAME "`r(wname)'"
  6. 
.     use "${TMP_PANEL_RAW}", clear
  7.     encode province, gen(pid)
  8.     xtset pid year
  9. 
.     capture log close sdm_`tag'
 10.     log using "${STATA_DIR}/SDM主模型_`tag'.log", text replace name(sdm_`t
> ag')
 11. 
.     display as text "============================================"
 12.     display as text "矩阵：`label' (`tag')"
 13.     display as text "双固定效应 SDM 主模型"
 14.     display as text "============================================"
 15. 
.     quietly xsmle eff lntl ind urb rd open es, ///
>         wmat(`WNAME') model(sdm) fe type(both) effect nolog
 16. 
.     ereturn display
 17.     return list
 18.     matrix `RTAB' = r(table)
 19. 
.     local cnames : colfullnames e(b)
 20.     local k = colsof(`RTAB')
 21. 
.     forvalues j = 1/`k' {
 22.         local token : word `j' of `cnames'
 23.         local clean = subinstr("`token'", ":", " ", .)
 24.         local section : word 1 of `clean'
 25.         local variable : word 2 of `clean'
 26. 
.         scalar b  = `RTAB'[1,`j']
 27.         scalar se = `RTAB'[2,`j']
 28.         scalar zz = `RTAB'[3,`j']
 29.         scalar pp = `RTAB'[4,`j']
 30.         scalar ll = `RTAB'[5,`j']
 31.         scalar ul = `RTAB'[6,`j']
 32. 
.         if inlist("`section'", "Main", "Wx", "Spatial", "Variance") {
 33.             post coef_handle ("`tag'") ("`section'") ("`variable'") ///
>                 (b) (se) (zz) (pp) (ll) (ul)
 34.         }
 35.         else if inlist("`section'", "LR_Direct", "LR_Indirect", "LR_Total"
> ) {
 36.             post effect_handle ("`tag'") ("`section'") ("`variable'") ///
>                 (b) (se) (zz) (pp) (ll) (ul)
 37.         }
 38.     }
 39. 
.     log close sdm_`tag'
 40. end

. 
