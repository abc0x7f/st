. * ------------------------------
. * 6. 单个矩阵的完整检验流程
. * ------------------------------
. capture program drop run_one_matrix

. program define run_one_matrix
  1.     syntax , TAG(string) LABEL(string) WFILE(string)
  2. 
.     tempname W WLM
  3.     tempfile province_order wdiag_dta
  4.     local df_time = ${T_PERIOD} - 1
  5.     local df_ind  = ${N_CROSS} - 1
  6. 
.     preserve
  7.         import delimited using "`wfile'", clear varnames(1) encoding(utf8)
>  stringcols(1)
  8.         gen order_id = _n
  9.         keep province order_id
 10.         save "`province_order'", replace
 11.     restore
 12. 
.     quietly build_w_matrix, wfile("`wfile'") wname(`W')
 13.     local WNAME "`r(wname)'"
 14. 
.     use "${TMP_PANEL_RAW}", clear
 15.     merge m:1 province using "`province_order'", keep(match) nogen
 16.     sort order_id year
 17. 
.     gen pid = order_id
 18.     xtset pid year
 19. 
.     preserve
 20.         clear
 21.         mata: st_matrix("`WLM'", panel_blockdiag(st_matrix("`WNAME'"), ${T
> _PERIOD}))
 22.         svmat `WLM', names(col)
 23.         save "`wdiag_dta'", replace
 24.     restore
 25. 
.     capture spatwmat drop `WLM'
 26.     quietly spatwmat using "`wdiag_dta'", name(`WLM') standardize
 27. 
.     * ----------------------------------------
.     * A. LM / Robust LM
.     * ----------------------------------------
.     capture log close lm_`tag'
 28.     log using "${STATA_DIR}/LM_`tag'.log", text replace name(lm_`tag')
 29. 
.     display as text "============================================"
 30.     display as text "矩阵：`label' (`tag')"
 31.     display as text "LM / Robust LM 检验"
 32.     display as text "============================================"
 33. 
.     quietly tabulate pid, generate(pid_d_)
 34.     quietly tabulate year, generate(year_d_)
 35. 
.     regress eff lntl ind urb rd open es pid_d_2-pid_d_${N_CROSS} year_d_2-yea
> r_d_${T_PERIOD}
 36. 
.     noisily spatdiag, weights(`WLM')
 37.     return list
 38. 
.     capture confirm matrix r(stats)
 39.     if !_rc {
 40.         matrix list r(stats)
 41.     }
 42. 
.     capture confirm matrix r(stats)
 43.     if !_rc {
 44.         tempname LMSTAT
 45.         matrix `LMSTAT' = r(stats)
 46.         post lm_handle ("`tag'") ("LM Error") (`LMSTAT'[2,1]) (`LMSTAT'[2,
> 2]) (`LMSTAT'[2,3])
 47.         post lm_handle ("`tag'") ("Robust LM Error") (`LMSTAT'[3,1]) (`LMS
> TAT'[3,2]) (`LMSTAT'[3,3])
 48.         post lm_handle ("`tag'") ("LM Lag") (`LMSTAT'[4,1]) (`LMSTAT'[4,2]
> ) (`LMSTAT'[4,3])
 49.         post lm_handle ("`tag'") ("Robust LM Lag") (`LMSTAT'[5,1]) (`LMSTA
> T'[5,2]) (`LMSTAT'[5,3])
 50.     }
 51. 
.     log close lm_`tag'
 52. 
.     * ----------------------------------------
.     * B. LR：个体 / 时间 / 双固定 SDM
.     * ----------------------------------------
.     capture log close sdm_`tag'
 53.     log using "${STATA_DIR}/模型结果_`tag'.log", text replace name(sdm_`ta
> g')
 54. 
.     display as text "============================================"
 55.     display as text "矩阵：`label' (`tag')"
 56.     display as text "SDM 个体 / 时间 / 双固定估计"
 57.     display as text "============================================"
 58. 
.     quietly xsmle eff lntl ind urb rd open es, ///
>         wmat(`WNAME') model(sdm) fe type(ind) nolog noeffects
 59.     estimates store ind_`tag'
 60.     estimates restore ind_`tag'
 61.     ereturn display
 62. 
.     quietly xsmle eff lntl ind urb rd open es, ///
>         wmat(`WNAME') model(sdm) fe type(time) nolog noeffects
 63.     estimates store time_`tag'
 64.     estimates restore time_`tag'
 65.     ereturn display
 66. 
.     quietly xsmle eff lntl ind urb rd open es, ///
>         wmat(`WNAME') model(sdm) fe type(both) nolog noeffects
 67.     estimates store both_`tag'
 68.     estimates restore both_`tag'
 69.     ereturn display
 70. 
.     display as text "--------------------------------------------"
 71.     display as text "LR 检验"
 72.     display as text "--------------------------------------------"
 73. 
.     quietly lrtest both_`tag' ind_`tag', df(`df_time')
 74.     post lr_handle ("`tag'") ("LR: both vs ind") (r(chi2)) (`df_time') (r(
> p))
 75.     noisily lrtest both_`tag' ind_`tag', df(`df_time')
 76. 
.     quietly lrtest both_`tag' time_`tag', df(`df_ind')
 77.     post lr_handle ("`tag'") ("LR: both vs time") (r(chi2)) (`df_ind') (r(
> p))
 78.     noisily lrtest both_`tag' time_`tag', df(`df_ind')
 79. 
.     * ----------------------------------------
.     * C. Wald：SDM -> SAR / SDM -> SEM
.     * ----------------------------------------
.     display as text "--------------------------------------------"
 80.     display as text "Wald 检验"
 81.     display as text "--------------------------------------------"
 82. 
.     quietly estimates restore both_`tag'
 83. 
.     quietly test ///
>         ([Wx]lntl = 0) ///
>         ([Wx]ind  = 0) ///
>         ([Wx]urb  = 0) ///
>         ([Wx]rd   = 0) ///
>         ([Wx]open = 0) ///
>         ([Wx]es   = 0)
 84.     post wald_handle ("`tag'") ("Wald: SDM -> SAR") (r(chi2)) (r(df)) (r(p
> ))
 85.     noisily test ///
>         ([Wx]lntl = 0) ///
>         ([Wx]ind  = 0) ///
>         ([Wx]urb  = 0) ///
>         ([Wx]rd   = 0) ///
>         ([Wx]open = 0) ///
>         ([Wx]es   = 0)
 86. 
.     quietly testnl ///
>         ([Wx]lntl = -[Spatial]rho*[Main]lntl) ///
>         ([Wx]ind  = -[Spatial]rho*[Main]ind) ///
>         ([Wx]urb  = -[Spatial]rho*[Main]urb) ///
>         ([Wx]rd   = -[Spatial]rho*[Main]rd) ///
>         ([Wx]open = -[Spatial]rho*[Main]open) ///
>         ([Wx]es   = -[Spatial]rho*[Main]es)
 87.     post wald_handle ("`tag'") ("Wald: SDM -> SEM") (r(chi2)) (r(df)) (r(p
> ))
 88.     noisily testnl ///
>         ([Wx]lntl = -[Spatial]rho*[Main]lntl) ///
>         ([Wx]ind  = -[Spatial]rho*[Main]ind) ///
>         ([Wx]urb  = -[Spatial]rho*[Main]urb) ///
>         ([Wx]rd   = -[Spatial]rho*[Main]rd) ///
>         ([Wx]open = -[Spatial]rho*[Main]open) ///
>         ([Wx]es   = -[Spatial]rho*[Main]es)
 89. 
.     log close sdm_`tag'
 90. end

. 
