. * ------------------------------
. * 2. Mata 辅助函数
. * ------------------------------
. mata:
------------------------------------------------- mata (type end to exit) -----
: real matrix row_normalize(real matrix W)
> {
>     real scalar i, s
>     real matrix R
> 
>     R = W
>     for (i = 1; i <= rows(R); i++) {
>         s = sum(R[i,])
>         if (s != 0) {
>             R[i,] = R[i,] :/ s
>         }
>     }
>     return(R)
> }

: 
: real matrix panel_blockdiag(real matrix W, real scalar T)
> {
>     real scalar t, n, r1, r2, c1, c2
>     real matrix P
> 
>     n = rows(W)
>     P = J(n*T, n*T, 0)
>     for (t = 1; t <= T; t++) {
>         r1 = (t - 1) * n + 1
>         r2 = t * n
>         c1 = (t - 1) * n + 1
>         c2 = t * n
>         P[|r1, c1 \ r2, c2|] = W
>     }
>     return(P)
> }

: end
-------------------------------------------------------------------------------

